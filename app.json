{
  "expo": {
    "name": "贷款助手",
    "slug": "loan-helper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loanhelper.app",
      "infoPlist": {
        "NSCameraUsageDescription": "需要相机权限来扫描身份证、营业执照等贷款资料",
        "NSPhotoLibraryUsageDescription": "需要相册权限来选择客户已有的图片",
        "NSPhotoLibraryAddUsageDescription": "需要权限来保存资料照片",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-camera",
      "expo-sqlite",
      "expo-document-picker",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "8f708a2d-424e-44f2-933e-936ffb5286c3"
      }
    },
    "owner": "auntyang"
  }
}